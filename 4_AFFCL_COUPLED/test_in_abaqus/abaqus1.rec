    ANALYTIC_RIGID_SURFACE)
mdb.models['Model-1'].parts['probe'].AnalyticRigidSurfRevolve(sketch=
    mdb.models['Model-1'].sketches['__profile__'])
del mdb.models['Model-1'].sketches['__profile__']
mdb.models['Model-1'].Material(name='Material-1')
mdb.models['Model-1'].materials['Material-1'].Elastic(table=((1.0, 0.45), ))
mdb.models['Model-1'].HomogeneousSolidSection(material='Material-1', name=
    'SECTION_elastic', thickness=None)
mdb.models['Model-1'].parts['cube'].Set(cells=
    mdb.models['Model-1'].parts['cube'].cells.getSequenceFromMask(('[#1 ]', ), 
    ), name='Set-Cube')
mdb.models['Model-1'].parts['cube'].SectionAssignment(offset=0.0, offsetField=
    '', offsetType=MIDDLE_SURFACE, region=
    mdb.models['Model-1'].parts['cube'].sets['Set-Cube'], sectionName=
    'SECTION_elastic', thicknessAssignment=FROM_SECTION)
mdb.models['Model-1'].rootAssembly.DatumCsysByDefault(CARTESIAN)
mdb.models['Model-1'].rootAssembly.Instance(dependent=OFF, name='cube-1', part=
    mdb.models['Model-1'].parts['cube'])
mdb.models['Model-1'].rootAssembly.Instance(dependent=OFF, name='probe-1', 
    part=mdb.models['Model-1'].parts['probe'])
mdb.models['Model-1'].rootAssembly.instances['probe-1'].translate(vector=(3.2, 
    0.0, 0.0))
mdb.models['Model-1'].parts['probe'].ReferencePoint(point=
    mdb.models['Model-1'].parts['probe'].vertices[0])
mdb.models['Model-1'].rootAssembly.regenerate()
