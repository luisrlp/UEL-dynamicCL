mdb.models['Model-1'].StaticStep(name='indentation', nlgeom=ON, previous=
    'Initial')
mdb.models['Model-1'].ContactProperty('IntProp-1')
mdb.models['Model-1'].interactionProperties['IntProp-1'].TangentialBehavior(
    formulation=FRICTIONLESS)
mdb.models['Model-1'].rootAssembly.Surface(name='Surface-Probe', side1Faces=
