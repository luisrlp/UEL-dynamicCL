mdb.models['Model-1'].SurfaceToSurfaceContactStd(adjustMethod=NONE, 
    clearanceRegion=None, createStepName='indentation', datumAxis=None, 
    initialClearance=OMIT, interactionProperty='IntProp-1', main=
    mdb.models['Model-1'].rootAssembly.surfaces['Surface-Probe'], name=
    'INTERACTION-Contact', secondary=
    mdb.models['Model-1'].rootAssembly.surfaces['SURFACE-Top'], sliding=FINITE, 
    thickness=ON)
mdb.models['Model-1'].interactionProperties.changeKey(fromName='IntProp-1', 
    toName='INTPROP-Frictionless')
mdb.models['Model-1'].rootAssembly.Set(name='Set-RP', referencePoints=(
    mdb.models['Model-1'].rootAssembly.instances['probe-1'].referencePoints[3], 
    ))
mdb.models['Model-1'].DisplacementBC(amplitude=UNSET, createStepName=
